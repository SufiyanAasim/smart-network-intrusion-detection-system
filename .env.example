# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Host-side ports used by docker-compose.yml (container ports stay fixed).
NIDS_DASHBOARD_PORT=8501
NIDS_API_EXPOSE_PORT=8600
# Version-neutral persistent Compose volume. Existing installations may set
# this to their previous volume name during an upgrade.
NIDS_HISTORY_VOLUME=nids-history

# Live capture (Tab 1) needs elevated/admin privileges on most OSes
# to open a raw socket. No credentials required by default.
LIVE_BATCH_SIZE=5
LIVE_SNIFF_TIMEOUT=1
# Minimum time between visible dashboard refreshes while capture is running.
LIVE_REFRESH_SECONDS=2.5
# Optional adapter identifier or exact label shown in the Capture interface
# selector. Leave empty to use Scapy's route-selected default.
NIDS_CAPTURE_INTERFACE=

# PCAP/PCAPNG safety limit. Keep in sync with server.maxUploadSize in
# .streamlit/config.toml when changing it.
MAX_PCAP_UPLOAD_MB=50

# --- Critical-threat alerting (all optional; unset = that channel is skipped) ---
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
# PagerDuty Events API v2 integration/routing key.
PAGERDUTY_ROUTING_KEY=
# Microsoft Teams incoming-webhook URL.
TEAMS_WEBHOOK_URL=
# Minimum seconds between two alerts for the same model (avoids spamming
# during a sustained attack).
ALERT_COOLDOWN_SECONDS=60

# Default value for the sidebar's CRITICAL threshold slider (% of traffic
# flagged as attack before status escalates to CRITICAL). Adjustable live
# in the UI; this only sets the initial value.
CRITICAL_THRESHOLD_PCT=20

# Optional: path to a MaxMind GeoLite2-City .mmdb database. When set (and the
# `geoip2` package is installed), the History tab plots public source IPs on
# a world map. Without it, only the IP-type breakdown is shown.
GEOIP_DB_PATH=

# --- Optional dashboard login (off by default) ---
# Leave NIDS_AUTH_PASSWORD_HASH empty to run the app open (no login).
# To enable a login gate, generate a hash with `python src/nids/auth.py`
# (it prompts for a password and prints the line to paste here) and set it
# below. Never put a plaintext password here.
NIDS_AUTH_USERNAME=admin
NIDS_AUTH_PASSWORD_HASH=pbkdf2_sha256$260000$0b331d1815877bee7eb89bfd59a80c05$5521f5a3bb793d1c3186d31c9b174569f1b8bbd20f3a4502c9fbb99a7f07e88f

# Multi-user (overrides the single-user pair above). A JSON list of users;
# role is "admin" or "viewer". Generate each hash with `python src/nids/auth.py`.
# Example with admin (admin@584) and viewer (viewer@584):
NIDS_AUTH_USERS=[{"username":"admin","password_hash":"pbkdf2_sha256$260000$0b331d1815877bee7eb89bfd59a80c05$5521f5a3bb793d1c3186d31c9b174569f1b8bbd20f3a4502c9fbb99a7f07e88f","role":"admin"},{"username":"viewer","password_hash":"pbkdf2_sha256$260000$e96cbb9b569fc90a71fe223d06a1de8b$3da1691d13748a814d37c3e5f191b1a95c7b002ff7bce351f9f81bdfff9ed9ed","role":"viewer"}]

# Optional self-service account creation. New accounts are always Viewers;
# Administrators must be provisioned above. Keep disabled on public deployments.
NIDS_SIGNUP_ENABLED=true
NIDS_AUTH_DB_PATH=data/auth.db

# --- REST API (python src/nids/api.py) ---
NIDS_API_HOST=127.0.0.1
NIDS_API_PORT=8600
# Optional bearer token; when set, clients must send Authorization: Bearer <token>.
NIDS_API_TOKEN=

# --- Encrypted history-db backup ---
# Base64 Fernet key enabling the "Encrypted backup" button. Generate one with:
#   python -c "from nids.crypto import generate_key; print(generate_key())"
NIDS_DB_ENCRYPTION_KEY=

# --- Cipher v11 policy-governed autonomous response ---
# Safe default: correlate and audit decisions without changing host state.
NIDS_AUTONOMY_MODE=shadow
NIDS_AUTONOMY_EXECUTE=false
NIDS_AUTONOMY_MIN_RISK=90
NIDS_AUTONOMY_MIN_EVENTS=3
NIDS_AUTONOMY_WINDOW_SECONDS=300
NIDS_AUTONOMY_BLOCK_TTL_MINUTES=30
NIDS_AUTONOMY_MAX_ACTIVE_BLOCKS=5
# Private/LAN sources are protected unless an operator deliberately opts in.
NIDS_AUTONOMY_ALLOW_PRIVATE=false
